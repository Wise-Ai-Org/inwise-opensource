{
  "name": "inwise-opensource",
  "version": "1.0.0",
  "description": "Open-source AI meeting recorder — local transcription, local storage, your own API key",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "npm run build && electron .",
    "dev": "concurrently \"npm run watch:main\" \"npm run watch:renderer\" \"wait-on dist/main/main.js dist/renderer/bundle.js && electron .\"",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "watch:main": "tsc -p tsconfig.main.json --watch",
    "watch:renderer": "webpack --config webpack.renderer.config.js --watch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@azure/msal-node": "^2.16.2",
    "electron-store": "^8.2.0",
    "node-ical": "^0.25.6",
    "node-sqlite3-wasm": "^0.8.55",
    "nodejs-whisper": "^0.1.18",
    "openai": "^4.67.0",
    "react-router-dom": "^6.26.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/react-router-dom": "^5.3.3",
    "@types/uuid": "^9.0.0",
    "concurrently": "^8.2.0",
    "css-loader": "^6.8.1",
    "electron": "^31.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.0",
    "wait-on": "^7.2.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  }
}
